# ===== $HUSH airdrop backend config =====
# Copy this file to ".env" and fill in. Without a payer key the backend runs in
# safe DRY-RUN mode: it reads REAL on-chain data but never moves funds.

# Solana RPC. Public mainnet works for reads but rate-limits getProgramAccounts.
# For real holder snapshots use a provider RPC (Helius / QuickNode / Triton).
RPC_URL=https://api.mainnet-beta.solana.com

# The $HUSH SPL mint (the pump.fun token).
HUSH_MINT=CvyAHeWHhuyGHWp8Rvu1j7FPSv5pJNdoLuTudd8Mpump

# The wallet that collects pump.fun creator fees. Its SOL balance is the "vault".
# (Set to the creator-fee recipient address. Defaults to the payer if omitted.)
FEE_WALLET=

# Base58-encoded secret key of the PAYER that funds airdrops (the creator wallet).
# REQUIRED to actually send SOL. Leave blank to stay in dry-run mode.
# NEVER commit a real key. Phantom: Settings > Export Private Key.
PAYER_SECRET_KEY=

# Set to "true" to actually broadcast transactions. Any other value = dry-run.
ARMED=false

# Port for the local server (serves the website + /api).
PORT=8080
